---
/**
 * Header Component
 * Per ANS-486: "Header menu - Nearly perfect, minimal changes"
 * Using ghost button variant for softer appearance
 *
 * `dark` renders the navy-950 variant used over the marketing home hero, and
 * exposes the CLI installation path as the primary CTA.
 */
interface Props {
  dark?: boolean;
}
const { dark = false } = Astro.props;

const currentPath = Astro.url.pathname;

const navLinks = [
  { href: '/discover', label: 'Explore' },
  { href: '/trust', label: 'Trust' },
  { href: '/pricing', label: 'Pricing' },
  { href: '/architecture-diagram', label: 'Architecture' },
  { href: '/docs/overview', label: 'Docs' },
  { href: '/blog', label: 'Blog' },
];

const ctas = [
  { href: 'https://app.answerlayer.io/sign-up', label: 'Sign up', external: true, primary: true },
  { href: '/deploy', label: 'Deploy', external: false, primary: false },
];

const isActive = (href: string) =>
  currentPath === href || currentPath.startsWith(href + '/');
---

<header
  class:list={[
    'border-b-2 sticky top-0 z-50',
    dark ? 'border-navy-700 bg-navy-950' : 'border-navy-900 bg-white',
  ]}
>
  <div class="container mx-auto px-6">
    <div class="flex items-center justify-between" style="padding-top: 0.25rem; padding-bottom: 0.25rem;">
      <!-- Logo -->
      <a
        href="/"
        class:list={[
          'flex items-center gap-2 uppercase tracking-tight font-display font-bold hover:no-underline',
          dark ? 'text-navy-50' : 'text-navy-900',
        ]}
      >
        <img src="/logo.svg" alt="" width="24" height="24" class="w-6 h-6" />
        <span class="crt-text">AnswerLayer</span>
      </a>

      <!-- Desktop Navigation -->
      <nav class="hidden lg:flex items-center gap-6">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class:list={[
              'crt-text uppercase text-sm tracking-wide font-mono hover:underline transition-colors',
              isActive(link.href)
                ? (dark ? 'text-white font-bold' : 'text-navy-900 font-bold')
                : (dark ? 'text-navy-300 hover:text-white' : 'text-gray-600 hover:text-navy-900'),
            ]}
          >
            {link.label}
          </a>
        ))}
        <div class="flex items-center gap-2">
          {ctas.map((cta) => (
            <a
              href={cta.href}
              target={cta.external ? '_blank' : undefined}
              rel={cta.external ? 'noopener' : undefined}
              class:list={[
                'crt-text inline-flex items-center justify-center uppercase tracking-wide font-display font-semibold text-sm px-4 py-2 border-2 transition-all duration-150 hover:no-underline',
                cta.primary
                  ? (dark
                      ? 'border-navy-50 bg-navy-50 text-navy-950 hover:bg-navy-200'
                      : 'border-navy-900 bg-navy-900 text-white hover:bg-navy-700')
                  : (dark
                      ? 'border-navy-400 text-navy-50 hover:bg-navy-50 hover:text-navy-950'
                      : 'border-navy-900 text-navy-900 hover:bg-navy-900 hover:text-white'),
              ]}
            >
              {cta.label}
            </a>
          ))}
        </div>
      </nav>

      <!-- Mobile Menu Toggle -->
      <button
        class:list={[
          'lg:hidden border-2 px-4 py-2 uppercase text-sm font-display font-semibold transition-colors',
          dark
            ? 'border-navy-400 text-navy-50 hover:bg-navy-50 hover:text-navy-950'
            : 'border-navy-900 hover:bg-navy-900 hover:text-white',
        ]}
        id="nav-toggle"
        aria-label="Toggle navigation"
        aria-expanded="false"
      >
        Menu
      </button>
    </div>

    <!-- Mobile Navigation -->
    <nav
      class:list={[
        'hidden lg:hidden flex-col gap-2 pb-4 border-t pt-4',
        dark ? 'border-navy-800' : 'border-gray-200',
      ]}
      id="mobile-nav"
    >
      {navLinks.map((link) => (
        <a
          href={link.href}
          class:list={[
            'crt-text uppercase text-sm tracking-wide font-mono py-2 hover:underline',
            isActive(link.href)
              ? (dark ? 'text-white font-bold' : 'text-navy-900 font-bold')
              : (dark ? 'text-navy-300' : 'text-gray-600'),
          ]}
        >
          {link.label}
        </a>
      ))}
      {ctas.map((cta) => (
        <a
          href={cta.href}
          target={cta.external ? '_blank' : undefined}
          rel={cta.external ? 'noopener' : undefined}
          class:list={[
            'crt-text inline-flex items-center justify-center uppercase tracking-wide font-display font-semibold text-sm px-4 py-2 mt-2 border-2 transition-colors',
            cta.primary
              ? (dark
                  ? 'border-navy-50 bg-navy-50 text-navy-950 hover:bg-navy-200'
                  : 'border-navy-900 bg-navy-900 text-white hover:bg-navy-700')
              : (dark
                  ? 'border-navy-400 text-navy-50 hover:bg-navy-50 hover:text-navy-950'
                  : 'border-navy-900 text-navy-900 hover:bg-navy-900 hover:text-white'),
          ]}
        >
          {cta.label}
        </a>
      ))}
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById('nav-toggle');
  const mobileNav = document.getElementById('mobile-nav');

  toggle?.addEventListener('click', () => {
    const isOpen = mobileNav?.classList.contains('flex');

    if (isOpen) {
      mobileNav?.classList.remove('flex');
      mobileNav?.classList.add('hidden');
      toggle.setAttribute('aria-expanded', 'false');
    } else {
      mobileNav?.classList.remove('hidden');
      mobileNav?.classList.add('flex');
      toggle.setAttribute('aria-expanded', 'true');
    }
  });
</script>
