---
/**
 * Pricing Page
 *
 * Design-partner pricing: a flat platform fee + tiered embedded-user pricing,
 * with the FDE perk. Copy lives in src/content/home/copy.yaml (`pricing`).
 * Styled with the site design system (technical-border box, mono labels, crt-text).
 */
import Layout from '../layouts/Layout.astro';
import { getEntry } from 'astro:content';

const entry = await getEntry('home', 'copy');
if (!entry) throw new Error('Missing src/content/home/copy.yaml');
const p = entry.data.pricing;

const installUrl = '/install';
const talkUrl = 'https://calendly.com/josh-getanswerlayer/30min';
const ctas = entry.data.ctas;
---

<Layout
  title="Pricing - AnswerLayer"
  description="Simple design-partner pricing: a flat platform fee deployed in your own cloud, plus tiered pricing for embedded users."
>
  <div class="crt-screen">
    <div class="container mx-auto px-6 py-12 md:py-20">

      <!-- Page Header -->
      <div class="page-header">
        <h1 class="page-title crt-text">Pricing</h1>
        <p class="page-subtitle crt-text">{p.heading}</p>
      </div>

      <!-- Two-column price box -->
      <div class="price-box">
        <div class="price-col">
          <div class="price-label crt-text">{p.platform.label}</div>
          <div class="price-amount crt-text">{p.platform.price} <span class="price-unit">{p.platform.unit}</span></div>
          <p class="price-body crt-text">{p.platform.body}</p>
        </div>
        <div class="price-col">
          <div class="price-label crt-text">{p.users.label}</div>
          <div class="price-amount crt-text">{p.users.price} <span class="price-unit">{p.users.unit}</span></div>
          <p class="price-body crt-text">{p.users.body}</p>
        </div>
      </div>

      <!-- Design-partner perk -->
      <div class="perk">
        <span class="price-label crt-text">{p.perkLabel}</span>
        <p class="perk-body crt-text">{p.perkBody}</p>
      </div>

      <!-- CTA -->
      <div class="cta-row">
        <a href={installUrl} class="cta-button is-primary crt-text">{ctas.primary}</a>
        <a href={talkUrl} target="_blank" rel="noopener" class="cta-button crt-text">{ctas.secondary}</a>
      </div>

    </div>
  </div>
</Layout>

<style>
  .page-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .page-title {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 500;
    color: var(--color-navy-900);
    margin: 0 0 0.5rem 0;
  }

  .page-subtitle {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    color: var(--color-navy-500);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin: 0;
  }

  /* ---- Price box (matches the homepage pricing treatment) ---- */
  .price-box {
    position: relative;
    max-width: 48rem;
    margin: 0 auto;
    border: 2px solid var(--color-navy-900);
    display: grid;
    grid-template-columns: 1fr;
  }
  .price-box::before {
    content: "";
    position: absolute;
    inset: -6px;
    border: 1px solid var(--color-navy-300);
    pointer-events: none;
  }
  .price-col {
    padding: 2rem;
    border-top: 2px solid var(--color-navy-900);
  }
  .price-col:first-child { border-top: none; }
  @media (min-width: 640px) {
    .price-box { grid-template-columns: 1fr 1fr; }
    .price-col { border-top: none; }
    .price-col + .price-col { border-left: 2px solid var(--color-navy-900); }
  }
  .price-label {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-navy-500);
  }
  .price-amount {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 2.25rem;
    color: var(--color-navy-900);
    margin-top: 0.5rem;
  }
  .price-unit {
    font-family: var(--font-mono);
    font-size: 0.9375rem;
    font-weight: 400;
    color: var(--color-navy-500);
  }
  .price-body {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    color: var(--color-navy-700);
    line-height: 1.6;
    margin-top: 0.75rem;
  }

  .perk {
    max-width: 48rem;
    margin: 1.25rem auto 0;
    border: 2px solid var(--color-navy-900);
    background: var(--color-navy-50);
    padding: 1rem 2rem;
    text-align: center;
  }
  .perk-body {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 1.0625rem;
    color: var(--color-navy-900);
    margin-top: 0.5rem;
  }

  /* ---- CTA row (site pattern) ---- */
  .cta-row {
    margin-top: 3rem;
    text-align: center;
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: center;
  }
  .cta-button {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.75rem 2rem;
    text-decoration: none;
    display: inline-block;
    border: 2px solid var(--color-navy-900);
    color: var(--color-navy-900);
    background: transparent;
    transition: all 0.15s ease;
  }
  .cta-button:hover {
    background: var(--color-navy-900);
    color: var(--color-background);
    text-decoration: none;
  }
  .cta-button.is-primary {
    background: var(--color-navy-900);
    color: var(--color-background);
  }
  .cta-button.is-primary:hover {
    background: var(--color-navy-700);
    border-color: var(--color-navy-700);
  }
</style>
