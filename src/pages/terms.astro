  description="AnswerLayer Terms of Service for use of the platform, APIs, hosted services, and related offerings."
>
  <section class="section">
    <div class="container legal-content">
      <h1>Terms of Service</h1>

      <p class="text-sm text-gray-600 mb-2">Last updated: March 31, 2026</p>
      <p class="text-sm text-gray-600 mb-8">
