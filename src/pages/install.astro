---
/**
 * CLI installation and first-run path.
 *
 * The primary path is agent-first local evaluation. Deployment choices remain
 * available from /deploy.
 */
import Layout from '../layouts/Layout.astro';
import CopyCommand from '../components/CopyCommand.astro';
---

<Layout
  title="Install the AnswerLayer CLI"
  description="Install the AnswerLayer CLI to build and query governed context for your agents."
>
  <div class="crt-screen">
    <section class="container mx-auto px-6 py-12 md:py-20">
      <div class="page-header">
        <p class="eyebrow crt-text">Semantic factory for agents</p>
        <h1 class="page-title crt-text">Install the CLI. Let your agent take it from there.</h1>
        <p class="page-subtitle crt-text">Run AnswerLayer locally, connect a dedicated read-only database user, and test against real data without creating a hosted account.</p>
      </div>

      <div class="steps">
        <article class="topic-card">
          <span class="step-number crt-text">01</span>
          <h2 class="card-title crt-text">Install the CLI</h2>
          <p class="card-description crt-text">The CLI runs on Node.js 20 or newer.</p>
          <div class="command-row"><CopyCommand command="npm install -g @answerlayer/cli" /></div>
          <p class="card-description crt-text">Prefer not to install it globally? Run <code>npx -y @answerlayer/cli --help</code>.</p>
        </article>

        <article class="topic-card">
          <span class="step-number crt-text">02</span>
          <h2 class="card-title crt-text">Install the agent skill</h2>
          <p class="card-description crt-text">The CLI includes a Codex skill that knows how to prepare, start, and verify the local stack.</p>
          <div class="command-row"><CopyCommand command="answerlayer skills install" /></div>
          <p class="card-description crt-text">Then ask your agent: “Start AnswerLayer locally and help me connect a read-only database safely.”</p>
        </article>

        <article class="topic-card">
          <span class="step-number crt-text">03</span>
          <h2 class="card-title crt-text">Start locally</h2>
          <p class="card-description crt-text">Your agent will confirm each state-changing step, prepare the local environment, start Docker Compose, and create a local-only organization and scoped CLI key.</p>
          <pre class="command crt-text"><code>git clone https://github.com/AnswerLayer/answerlayer-core.git
cd answerlayer-core
cp .env.example .env
docker compose up --build -d
make local-bootstrap</code></pre>
        </article>

        <article class="topic-card">
          <span class="step-number crt-text">04</span>
          <h2 class="card-title crt-text">Test real data safely</h2>
          <p class="card-description crt-text">Run the printed <code>answerlayer init</code> command, then connect a dedicated database account restricted to approved schemas and <code>SELECT</code> only.</p>
          <pre class="command crt-text"><code>answerlayer connections list
answerlayer inquiry ask --connection &lt;connection-id&gt; "What changed in revenue this month?"</code></pre>
        </article>
      </div>

      <div class="cta-row">
        <a href="https://github.com/AnswerLayer/answerlayer-cli" target="_blank" rel="noopener" class="cta-button is-primary crt-text">Read the CLI guide ↗</a>
        <a href="/docs/overview" class="cta-button crt-text">Read the API docs</a>
      </div>

      <p class="deployment-note crt-text">Need to deploy AnswerLayer into your own cloud? <a href="/deploy">Explore deployment options</a>.</p>
    </section>
  </div>
</Layout>

<style>
  .page-header {
    max-width: 48rem;
    margin: 0 auto 3rem;
    text-align: center;
  }

  .eyebrow,
  .step-number {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-navy-500);
  }

  .eyebrow { margin: 0 0 1rem; }

  .page-title {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 500;
    line-height: 1.1;
    text-transform: uppercase;
    color: var(--color-navy-900);
  }

  .page-subtitle {
    margin: 1rem 0 0;
    font-family: var(--font-body);
    font-size: 1.125rem;
    line-height: 1.6;
    color: var(--color-navy-700);
  }

  .steps {
    display: grid;
    gap: 1rem;
    max-width: 56rem;
    margin: 0 auto;
  }

  .topic-card {
    position: relative;
    padding: 1.5rem;
    background: var(--color-navy-100);
    border: 2px solid var(--color-navy-300);
  }

  .step-number { display: block; margin-bottom: 0.5rem; }

  .card-title {
    margin: 0;
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 500;
    text-transform: uppercase;
    color: var(--color-navy-900);
  }

  .card-description {
    margin: 0.75rem 0 0;
    font-family: var(--font-body);
    line-height: 1.6;
    color: var(--color-navy-700);
  }

  .card-description code {
    font-family: var(--font-mono);
    font-size: 0.875em;
  }

  .command {
    overflow-x: auto;
    margin: 1rem 0 0;
    padding: 1rem;
    background: var(--color-navy-900);
    color: var(--color-navy-50);
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    line-height: 1.65;
    white-space: pre-wrap;
  }

  .command-row { margin-top: 1rem; }

  .cta-row {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.75rem;
    margin: 2rem auto 0;
  }

  .deployment-note {
    margin: 1.5rem auto 0;
    text-align: center;
    font-family: var(--font-body);
    color: var(--color-navy-700);
  }

  .deployment-note a { color: var(--color-navy-900); }
</style>
