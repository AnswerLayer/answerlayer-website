---
/**
 * Docs - Dynamic Route
 *
 * Renders documentation pages from the docs content collection.
 * Includes a sidebar for navigation between doc pages.
 */
import Layout from '../../layouts/Layout.astro';
import { getCollection, getEntry } from 'astro:content';

export async function getStaticPaths() {
  const allDocs = await getCollection('docs');
  return allDocs.map((doc) => ({
    params: { slug: doc.slug },
    props: { slug: doc.slug },
  }));
}

const { slug } = Astro.props;
const entry = await getEntry('docs', slug);

if (!entry) {
  return Astro.redirect('/docs');
}

const { Content } = await entry.render();

// Build sidebar nav grouped by section
const allDocs = await getCollection('docs');
const sorted = allDocs.sort((a, b) => a.data.order - b.data.order);
const sections: Record<string, typeof sorted> = {};
for (const doc of sorted) {
  const section = doc.data.section;
  if (!sections[section]) sections[section] = [];
  sections[section].push(doc);
}
---

<Layout
  title={`${entry.data.title} - AnswerLayer Docs`}
  description={entry.data.description}
>
  <div class="docs-page">
    <div class="docs-container">

      <!-- Sidebar -->
      <nav class="docs-sidebar" aria-label="Documentation navigation">
        <a href="/docs" class="sidebar-home">Docs</a>
        {Object.entries(sections).map(([section, docs]) => (
          <div class="sidebar-section">
            <div class="sidebar-section-title">{section}</div>
            <ul class="sidebar-list">
              {docs.map((doc) => (
                <li>
                  <a
                    href={`/docs/${doc.slug}`}
                    class:list={['sidebar-link', { active: doc.slug === slug }]}
                    aria-current={doc.slug === slug ? 'page' : undefined}
                  >
                    {doc.data.title}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </nav>

      <!-- Content -->
      <article class="docs-content">
        <h1 class="docs-title">{entry.data.title}</h1>
        <div class="docs-body">
          <Content />
        </div>
      </article>

    </div>
  </div>
</Layout>

<style>
  .docs-page {
    min-height: calc(100vh - 160px);
  }

  .docs-container {
    max-width: 72rem;
    margin: 0 auto;
    display: flex;
    gap: 3rem;
    padding: 2rem 1.5rem 4rem;
  }

  /* Sidebar */
  .docs-sidebar {
    width: 220px;
    flex-shrink: 0;
    position: sticky;
    top: 6rem;
    align-self: flex-start;
    max-height: calc(100vh - 8rem);
    overflow-y: auto;
  }

  .sidebar-home {
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-navy-900);
    text-decoration: none;
    display: block;
    margin-bottom: 1.5rem;
  }

  .sidebar-section {
    margin-bottom: 1.25rem;
  }

  .sidebar-section-title {
    font-family: var(--font-body);
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-navy-500);
    margin-bottom: 0.5rem;
  }

  .sidebar-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .sidebar-link {
    display: block;
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 300;
    color: var(--color-navy-700);
    text-decoration: none;
    padding: 0.25rem 0.75rem;
    border-left: 2px solid transparent;
    transition: all 0.1s ease;
  }

  .sidebar-link:hover {
    color: var(--color-navy-900);
    border-left-color: var(--color-navy-300);
  }

  .sidebar-link.active {
    color: var(--color-navy-900);
    font-weight: 500;
    border-left-color: var(--color-navy-900);
  }

  /* Content */
  .docs-content {
    flex: 1;
    min-width: 0;
    max-width: 48rem;
  }

  .docs-title {
    font-family: var(--font-body);
    font-size: 2rem;
    font-weight: 600;
    color: var(--color-navy-900);
    margin: 0 0 2rem;
    line-height: 1.2;
  }

  .docs-body {
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 300;
    color: #374151;
    line-height: 1.8;
  }

  .docs-body :global(h2) {
    font-size: 1.375rem;
    font-weight: 600;
    color: var(--color-navy-900);
    margin: 2.5rem 0 1rem;
    line-height: 1.3;
  }

  .docs-body :global(h3) {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--color-navy-900);
    margin: 2rem 0 0.75rem;
    line-height: 1.3;
  }

  .docs-body :global(p) {
    margin-bottom: 1rem;
  }

  .docs-body :global(strong) {
    color: var(--color-navy-900);
    font-weight: 600;
  }

  .docs-body :global(code) {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    background: var(--color-navy-100);
    border: 1px solid var(--color-navy-300);
    padding: 0.125rem 0.375rem;
    color: var(--color-navy-900);
  }

  .docs-body :global(pre) {
    background: var(--color-navy-900);
    color: var(--color-navy-100);
    padding: 1rem 1.25rem;
    margin: 1rem 0 1.5rem;
    overflow-x: auto;
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    line-height: 1.6;
    border: 2px solid var(--color-navy-800);
  }

  .docs-body :global(pre code) {
    background: transparent;
    border: none;
    padding: 0;
    color: inherit;
    font-size: inherit;
  }

  .docs-body :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1rem 0 1.5rem;
    font-size: 0.875rem;
  }

  .docs-body :global(th),
  .docs-body :global(td) {
    border: 1px solid var(--color-navy-300);
    padding: 0.5rem 0.75rem;
    text-align: left;
  }

  .docs-body :global(th) {
    background: var(--color-navy-100);
    font-weight: 600;
    color: var(--color-navy-900);
  }

  .docs-body :global(ul),
  .docs-body :global(ol) {
    padding-left: 1.5rem;
    margin: 0.75rem 0 1.25rem;
  }

  .docs-body :global(li) {
    margin-bottom: 0.375rem;
  }

  /* Mobile: hide sidebar, full-width content */
  @media (max-width: 768px) {
    .docs-container {
      flex-direction: column;
      gap: 1.5rem;
    }

    .docs-sidebar {
      width: 100%;
      position: static;
      max-height: none;
      border-bottom: 1px solid var(--color-navy-200);
      padding-bottom: 1rem;
    }
  }
</style>
